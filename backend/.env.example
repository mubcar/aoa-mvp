# Server
PORT=3000
NODE_ENV=development

# Anthropic Claude API
ANTHROPIC_API_KEY=

# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Frontend URL (for CORS — comma-separated for multiple)
FRONTEND_URL=http://localhost:5173

# Webhook secret (shared with Evolution API)
WEBHOOK_SECRET=

# Evolution API (WhatsApp)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE_NAME=

# Vapi (Voice)
VAPI_API_KEY=
VAPI_WEBHOOK_SECRET=

# Admin panel
ADMIN_SECRET=          # Password for /admin — set something strong

# Calendly webhook (optional — add in Calendly dashboard under Webhooks)
CALENDLY_SIGNING_KEY=  # From Calendly → Integrations → Webhooks → Signing Key

# Feature flags
ENABLE_SOLANA_ESCROW=true # Set to false for production without Solana

# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_MERCHANT_WALLET=
SOLANA_NETWORK=devnet
USDC_MINT_ADDRESS=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
